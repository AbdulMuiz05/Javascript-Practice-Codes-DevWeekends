function calculateBMI(weight, height) {
    const bmi = weight / (height * height);
    console.log("BMI:", bmi.toFixed(2));

    if (bmi < 18.6)
        console.log("Underweight");
    else if (bmi <= 24.9)
        console.log("Normal");
    else
        console.log("Overweight");
}
calculateBMI(70, 1.75);
